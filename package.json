{
  "name": "mytripfy",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:guest": "playwright test e2e/api-health.spec.ts e2e/auth.spec.ts e2e/navigation.spec.ts e2e/oauth-flow.spec.ts e2e/smoke.spec.ts",
    "test:e2e:guest:prod": "cross-env CI=1 PLAYWRIGHT_BASE_URL=https://www.mytripfy.com playwright test e2e/api-health.spec.ts e2e/auth.spec.ts e2e/navigation.spec.ts e2e/oauth-flow.spec.ts e2e/smoke.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:desktop": "playwright test --project=desktop",
    "test:e2e:no-server": "cross-env CI=1 PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test",
    "lint": "eslint",
    "seed:translations": "node --env-file=.env.local scripts/seed-challenge-translations.mjs",
    "fetch:food-images": "node scripts/fetch-food-images.mjs",
    "delete-user": "node --env-file=.env.local scripts/delete-user-by-email.mjs",
    "icons": "node scripts/generate-favicon.mjs",
    "cap:prep": "node scripts/ensure-capacitor-web-dir.mjs && npx cap sync android",
    "android:bundle": "node scripts/run-android-bundle.mjs",
    "android:setup-keystore": "node scripts/setup-play-upload-keystore.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1000.0",
    "@aws-sdk/client-sesv2": "^3.1017.0",
    "@aws-sdk/client-support": "^3.1017.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@clerk/nextjs": "^7.0.6",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "resend": "^6.9.4",
    "svix": "^1.89.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^29.7.0",
    "png-to-ico": "^3.0.1",
    "shadcn": "^3.8.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-jest": "^29.2.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}

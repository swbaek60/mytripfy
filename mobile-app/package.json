{
  "name": "mytripfy-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "mytripfy – Find Travel Companions & Local Guides (Android / iOS)",
  "scripts": {
    "build": "echo No web build needed - app loads remote URL",
    "cap:sync": "node node_modules/@capacitor/cli/bin/capacitor sync",
    "cap:open:android": "node node_modules/@capacitor/cli/bin/capacitor open android",
    "cap:open:ios": "node node_modules/@capacitor/cli/bin/capacitor open ios",
    "android": "node node_modules/@capacitor/cli/bin/capacitor open android",
    "ios": "node node_modules/@capacitor/cli/bin/capacitor open ios"
  },
  "capacitor": {
    "platforms": ["android", "ios"]
  },
  "dependencies": {
    "@capacitor/core": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/ios": "^7.0.0"
  }
}
